flowchart LR
    U["User"] --> CHAT["/chat"]
    U --> PRIME["/calendar/cache/prime"]

    subgraph G["LangGraph booking_graph (/chat path)"]
      direction LR
      S["Build AgentState<br/>messages + prefs + trace_id"] --> START(("START"))
      START --> A["agent_node<br/>route_mode + mode-specific tools<br/>calendar_query cache fast-path (today/tomorrow)"]
      A --> SAN["sanitize tool calls<br/>inject user_id/timezone<br/>hydrate [event_id,start_iso]<br/>rewrite location follow-up<br/>book_event -> update_event_location"]
      SAN --> RA{"route_after_agent"}
      RA -->|tool_calls| TN["ToolNode"]
      RA -->|clarification / no tool| F["finalizer_node<br/>(single response surface)"]
      RA -->|needs_hitl| H["hitl_node"]
      TN --> TR["tool_result_node<br/>normalize execution_result"]
      TR --> RT{"route_after_tool_result"}
      RT -->|ok / error| F
      RT -->|conflict| H
      F --> END(("END"))
      H --> END
    end

    CHAT --> S
    END --> CRES["/chat ChatResponse<br/>status + summary + response_mode<br/>latest_event_id/latest_start_iso<br/>conflict mode: conversational summary (IST options)"]
    CRES --> CR["refresh cache after action<br/>status in created/updated/cancelled"]

    CRES -->|if conflict summary shown| UH["User replies preferred time in chat"] --> CH["/chat hitl follow-up<br/>resolve marker + parse time + retry book_event"]
    CH -->|still conflict| H["hitl_node (new marker + IST options)"]
    CH -->|created / updated / cancelled / error| HF["finalizer_node"] --> HRES["/chat ChatResponse<br/>same finalizer contract"]
    HRES --> CR

    CRES -.legacy/manual.-> HITL["/hitl/respond"]
    HITL --> RH["resolve_hitl_action<br/>(execution_result only)"] --> HF

    subgraph T["Calendar Tools (via ToolNode)"]
      direction TB
      Q["Query: find_events, check_availability,<br/>get_event_duration, get_event_location"]
      ACT["Action: book_event (overlap guard + alternatives),<br/>reschedule_event (id/hint resolve), cancel_event (id/hint resolve),<br/>update_event_duration, update_event_location,<br/>schedule_mutual"]
      MCP["MCPClient<br/>/tools/call -> REST fallback"]
      Q --> MCP
      ACT --> MCP
    end
    TN -.calls.-> Q
    TN -.calls.-> ACT

    subgraph P["Persistence / Context"]
      direction TB
      HIST["conversation_history<br/>(client-passed each turn)"]
      PREF["PreferencesRepo (SQLite)"]
      PEND["PendingActionRepo (SQLite)"]
      CACHE["EventCacheService (in-memory)<br/>today + tomorrow events"]
    end
    CHAT -.uses.-> HIST
    CHAT -.reads.-> PREF
    H -.writes.-> PEND
    HITL -.reads.-> PEND
    PRIME --> CACHE
    A -.query fast-path.-> CACHE
    CR --> CACHE
